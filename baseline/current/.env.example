# Nemo Agent Landing — переменные окружения (для справки)
# Реальные значения хранятся в `.env` (не коммитится, chmod 600)

# === Аналитика (опционально) ===
# Yandex.Metrika counter ID (получить на https://metrika.yandex.ru)
NEXT_PUBLIC_YANDEX_METRIKA_ID=
# Google Analytics 4 measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA4_ID=

# === Supabase (для личного кабинета, /account) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# === Layout-флаги ===
# Включить/выключить секции
NEXT_PUBLIC_SHOW_PRICING=true
NEXT_PUBLIC_SHOW_CALCULATOR=true
